{
  "name": "urbanmind-monorepo",
  "version": "1.0.0",
  "packageManager": "pnpm@10.34.2",
  "private": true,
  "description": "UrbanMind Capstone Project Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --dir apps/web dev",
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build",
    "dev:mobile": "pnpm --dir apps/mobile start"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
